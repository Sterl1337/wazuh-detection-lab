<group name="wazuh,lab,portfolio,">
  <!-- Lab-only rule: synthetic PowerShell download pattern -->
  <rule id="100100" level="8">
    <decoded_as>json</decoded_as>
    <field name="message">(?i)(DownloadString|Invoke-WebRequest)</field>
    <description>Lab: suspicious PowerShell download pattern</description>
    <mitre>
      <id>T1059</id>
    </mitre>
  </rule>

  <!-- Lab-only rule: synthetic archive staging -->
  <rule id="100110" level="7">
    <decoded_as>json</decoded_as>
    <field name="message">(?i)(\bzip\b|\b7z\b|\brar\b|\btar\b)</field>
    <description>Lab: suspicious archive staging</description>
    <mitre>
      <id>T1074</id>
    </mitre>
  </rule>

  <!-- Lab-only rule: repeated failed logons -->
  <rule id="100120" level="10">
    <decoded_as>json</decoded_as>
    <field name="message">(?i)(failed logon|authentication failure)</field>
    <description>Lab: repeated failed logon burst</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>
</group>
